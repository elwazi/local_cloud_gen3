apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: gen3
  namespace: argocd
spec:
  project: default
  source:
    repoURL: https://helm.gen3.org
    chart: gen3
    targetRevision: "0.3.36"
    helm:
      valuesObject:
        global:
          hostname: "{{ gen3.hostname }}"
          dev: false
          dictionaryUrl: "https://s3.amazonaws.com/dictionary-artifacts/datadictionary/develop/schema.json"
          postgres:
            dbCreate: true
            master:
              username: "{{ postgres.user }}"
              password: "{{ postgres.password }}"
              host: "{{ postgres.host_ip }}"
              port: "5432"
        fence:
          FENCE_CONFIG:
            OPENID_CONNECT:
              google:
                client_id: "{{ google_client_id }}"
                client_secret: "{{ google_client_secret }}"
            AWS_CREDENTIALS:
              "gen3":
                aws_access_key_id: "{{ garage.access_key }}"
                aws_secret_access_key: "{{ garage.secret_key }}"
            S3_BUCKETS:
              "{{ gen3.data_bucket_name }}":
                cred: "gen3"
                endpoint_url: "https://{{ s3.host_base }}"
              "{{ gen3.user_bucket_name | default(gen3.hostname ~ '-user-bucket') }}":
                cred: "gen3"
                endpoint_url: "https://{{ s3.host_base }}"
            DATA_UPLOAD_BUCKET: "{{ gen3.data_bucket_name }}"
          usersync:
            usersync: true
            userYamlS3Path: "s3://{{ gen3.user_bucket_name | default(gen3.hostname ~ '-user-bucket') }}/user.yaml"
        secrets:
          awsAccessKeyId: "{{ garage.access_key }}"
          awsSecretAccessKey: "{{ garage.secret_key }}"
        guppy:
          esEndpoint: "{{ postgres.host_ip }}:9200"
        revproxy:
          ingress:
            enabled: true
            className: "nginx"
            hosts:
              - host: "{{ gen3.hostname }}"
                paths:
                  - path: /
                    pathType: Prefix
        portal:
          enabled: true
          gitops:
            logo: "{{ _portal_logo['content'] }}"
            favicon: "{{ _portal_favicon['content'] }}"
            createdby: "{{ _portal_createdby['content'] }}"
            css: ""
            json: |
              {
                "graphql": {
                  "boardCounts": [
                    { "graphql": "_case_count", "name": "Case", "plural": "Cases" },
                    { "graphql": "_experiment_count", "name": "Experiment", "plural": "Experiments" },
                    { "graphql": "_aliquot_count", "name": "Aliquot", "plural": "Aliquots" }
                  ],
                  "chartCounts": [
                    { "graphql": "_case_count", "name": "Case" },
                    { "graphql": "_experiment_count", "name": "Experiment" },
                    { "graphql": "_aliquot_count", "name": "Aliquot" }
                  ],
                  "projectDetails": "boardCounts"
                },
                "components": {
                  "appName": "{{ gen3_portal.appName | default('Gen3 Data Commons') }}",
                  "index": {
                    "introduction": {
                      "heading": "{{ gen3_portal.heading | default('Gen3 Data Commons') }}",
                      "text": "{{ gen3_portal.intro_text | default('') }}",
                      "link": "/submission"
                    },
                    "buttons": [
                      { "name": "Define Data Field", "icon": "data-field-define", "body": "Browse the data dictionary.", "link": "/DD", "label": "Learn more" },
                      { "name": "Explore Data", "icon": "data-explore", "body": "Explore datasets.", "link": "/explorer", "label": "Explore data" },
                      { "name": "Access Data", "icon": "data-access", "body": "Query the data.", "link": "/query", "label": "Query data" },
                      { "name": "Submit Data", "icon": "data-submit", "body": "Submit data based on the dictionary.", "link": "/submission", "label": "Submit data" }
                    ]
                  },
                  "navigation": {
                    "title": "{{ gen3_portal.nav_title | default(gen3.hostname) }}",
                    "items": [
                      { "icon": "dictionary", "link": "/DD", "color": "#a2a2a2", "name": "Dictionary" },
                      { "icon": "exploration", "link": "/explorer", "color": "#a2a2a2", "name": "Exploration" },
                      { "icon": "query", "link": "/query", "color": "#a2a2a2", "name": "Query" },
                      { "icon": "workspace", "link": "/workspace", "color": "#a2a2a2", "name": "Workspace" },
                      { "icon": "profile", "link": "/identity", "color": "#a2a2a2", "name": "Profile" }
                    ]
                  },
                  "topBar": {
                    "items": [
                      { "icon": "upload", "link": "/submission", "name": "Submit Data" },
                      { "link": "https://gen3.org/resources/user", "name": "Documentation" }
                    ]
                  },
                  "login": {
                    "title": "{{ gen3_portal.login_title | default('Gen3 Data Commons') }}",
                    "subTitle": "{{ gen3_portal.login_subtitle | default('') }}",
                    "text": "{{ gen3_portal.login_text | default('') }}",
                    "contact": "If you have any questions about access or the registration process, please contact ",
                    "email": "{{ gen3.admin_email }}"
                  },
                  "certs": {},
                  "footerLogos": [
                    { "src": "/src/img/gen3.png", "href": "https://ctds.uchicago.edu/gen3", "alt": "Gen3 Data Commons" }
                    {% set mime_types = {'svg': 'image/svg+xml', 'png': 'image/png', 'jpg': 'image/jpeg', 'jpeg': 'image/jpeg'} %}
                    {% for result in _portal_sponsors.results %}
                    {% set ext = result.item.file.split('.')[-1] | lower %}
                    ,{ "src": "data:{{ mime_types[ext] | default('image/png') }};base64,{{ result.content }}", "href": "{{ result.item.href }}", "alt": "{{ result.item.alt }}" }
                    {% endfor %}
                  ]
                },
                "requiredCerts": [],
                "featureFlags": {
                  "explorer": true,
                  "noIndex": true,
                  "analysis": false,
                  "discovery": false,
                  "discoveryUseAggMDS": false,
                  "studyRegistration": false
                },
                "dataExplorerConfig": {
                  "charts": {
                    "project_id": { "chartType": "count", "title": "Projects" },
                    "_case_id": { "chartType": "count", "title": "Cases" },
                    "gender": { "chartType": "pie", "title": "Gender" },
                    "race": { "chartType": "bar", "title": "Race" }
                  },
                  "filters": {
                    "tabs": [{ "title": "Case", "fields": ["project_id", "gender", "race", "ethnicity"] }]
                  },
                  "table": { "enabled": false },
                  "dropdowns": {},
                  "buttons": [],
                  "guppyConfig": {
                    "dataType": "case",
                    "nodeCountTitle": "Cases",
                    "fieldMapping": [
                      { "field": "disease_type", "name": "Disease type" },
                      { "field": "primary_site", "name": "Site where samples were collected" }
                    ],
                    "manifestMapping": {
                      "resourceIndexType": "file",
                      "resourceIdField": "object_id",
                      "referenceIdFieldInResourceIndex": "_case_id",
                      "referenceIdFieldInDataIndex": "node_id"
                    },
                    "accessibleFieldCheckList": ["_case_id"],
                    "accessibleValidationField": "_case_id"
                  }
                },
                "fileExplorerConfig": {
                  "charts": {
                    "data_type": { "chartType": "stackedBar", "title": "File Type" },
                    "data_format": { "chartType": "stackedBar", "title": "File Format" }
                  },
                  "filters": {
                    "tabs": [{ "title": "File", "fields": ["project_id", "data_type", "data_format"] }]
                  },
                  "table": {
                    "enabled": true,
                    "fields": ["project_id", "file_name", "file_size", "object_id"]
                  },
                  "dropdowns": {},
                  "guppyConfig": {
                    "dataType": "file",
                    "fieldMapping": [{ "field": "object_id", "name": "GUID" }],
                    "nodeCountTitle": "Files",
                    "manifestMapping": {
                      "resourceIndexType": "case",
                      "resourceIdField": "_case_id",
                      "referenceIdFieldInResourceIndex": "object_id",
                      "referenceIdFieldInDataIndex": "object_id"
                    },
                    "accessibleFieldCheckList": ["_case_id"],
                    "accessibleValidationField": "_case_id",
                    "downloadAccessor": "object_id"
                  }
                }
              }
  destination:
    server: https://kubernetes.default.svc
    namespace: gen3
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
